# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/
# Exclude launch configs — contain secrets (dart-define API keys)
.vscode/launch.json
.cursor/launch.json

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Internal docs — not for the public repo
PUBLISH_NEXT_STEPS.md
SECURITY.md
STORE_METADATA.md

# Firebase config (real values generated by `flutterfire configure`)
lib/firebase_options.dart
**/google-services.json
**/GoogleService-Info.plist

# Signing / credentials — never commit
**/key.properties
*.jks
*.keystore
*.p12
*.p8
